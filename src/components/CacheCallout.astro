---
// CacheCallout.astro — static, no JS.
// Used as a chapter-closing takeaway across both Part I (cache topics) and
// Part II (extension topics). The amber visual is intentional continuity,
// not a strict "cache hit" marker.
//
// Public API (do not rename — existing MDX imports this by name):
//   <CacheCallout>…slot content…</CacheCallout>
//   <CacheCallout label="Custom label">…slot content…</CacheCallout>
//
// Part I uses "How this connects to the transformer"; Part II chapters
// pass an explicit override when the transformer angle doesn't fit.

const { label = 'How this connects to the transformer' } = Astro.props;
---

<aside class="cache-callout">
  <div class="cache-callout__label">{label}</div>
  <div class="cache-callout__body">
    <slot />
  </div>
</aside>

<style>
  .cache-callout {
    background: var(--color-cache-soft);
    border: 1px solid var(--color-cache);
    border-left-width: 4px;
    border-radius: var(--radius);
    padding: var(--space-4) var(--space-6);
    margin-top: var(--space-8);
    max-width: var(--content-max);
  }

  .cache-callout__label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #92400e; /* amber-800 for contrast on soft amber bg */
    margin-bottom: var(--space-2);
  }

  .cache-callout__body {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-text);
  }

  .cache-callout__body :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
